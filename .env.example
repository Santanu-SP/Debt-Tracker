# PocketSafe Environment Configuration Template
# Copy this file to .env and configure these parameters

MONGODB_URI=mongodb+srv://<db_username>:<db_password>@cluster.mongodb.net/pocketsafe?retryWrites=true&w=majority
PORT=3000

# Google OAuth Client ID (Get this from Google Cloud Console Credentials page)
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
